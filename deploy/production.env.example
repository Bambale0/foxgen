# Copy to /root/foxgen/.env on the production server and replace every placeholder.
# This file is documentation only; the deploy workflow never uploads or overwrites .env.

FOXGEN_ENV=production
FOXGEN_LOG_LEVEL=INFO
FOXGEN_API_HOST=0.0.0.0
FOXGEN_API_PORT=8080
FOXGEN_PUBLIC_API_PORT=8080

FOXGEN_TELEGRAM_BOT_TOKEN=<telegram-bot-token>
FOXGEN_TELEGRAM_FSM_TTL_SECONDS=3600
FOXGEN_TELEGRAM_INPUT_MAX_BYTES=52428800
FOXGEN_TELEGRAM_INPUT_PRESIGNED_URL_TTL_SECONDS=21600

FOXGEN_POSTGRES_DB=foxgen
FOXGEN_POSTGRES_USER=foxgen
FOXGEN_POSTGRES_PASSWORD=<long-random-postgres-password>
FOXGEN_DATABASE_URL=postgresql+asyncpg://foxgen:<url-encoded-postgres-password>@postgres:5432/foxgen

FOXGEN_REDIS_PASSWORD=<long-random-redis-password>
FOXGEN_REDIS_URL=redis://:<url-encoded-redis-password>@redis:6379/0

FOXGEN_INTERNAL_API_BASE_URL=http://api:8080
FOXGEN_INTERNAL_API_TIMEOUT_SECONDS=30
FOXGEN_INTERNAL_API_TOKEN=<long-random-internal-api-token>

FOXGEN_KIE_API_KEY=<kie-api-key>
FOXGEN_KIE_BASE_URL=https://api.kie.ai
FOXGEN_KIE_CALLBACK_BASE_URL=https://foxgen.example.com
FOXGEN_KIE_WEBHOOK_HMAC_KEY=<long-random-webhook-secret>
FOXGEN_WEBHOOK_MAX_AGE_SECONDS=300

FOXGEN_TASK_SUBMISSION_ENABLED=false
FOXGEN_SUBMISSION_USER_RATE_LIMIT_PER_MINUTE=10
FOXGEN_SUBMISSION_GLOBAL_RATE_LIMIT_PER_MINUTE=100
FOXGEN_SUBMISSION_USER_CONCURRENCY_LIMIT=2
FOXGEN_SUBMISSION_GLOBAL_CONCURRENCY_LIMIT=20

FOXGEN_BILLING_ADMIN_API_ENABLED=false
FOXGEN_BILLING_ADMIN_API_TOKEN=<separate-long-random-admin-token>

FOXGEN_WORKER_LOOP_INTERVAL_SECONDS=1
FOXGEN_WORKER_OUTBOX_BATCH_SIZE=10
FOXGEN_WORKER_OUTBOX_LEASE_SECONDS=120
FOXGEN_WORKER_OUTBOX_MAX_ATTEMPTS=8
FOXGEN_PROVIDER_POLL_INTERVAL_SECONDS=20
FOXGEN_STALE_SUBMITTING_SECONDS=600

FOXGEN_MEDIA_DOWNLOAD_TIMEOUT_SECONDS=60
FOXGEN_MEDIA_MAX_BYTES=536870912
FOXGEN_MEDIA_PRESIGNED_URL_TTL_SECONDS=3600

# Private MinIO inside docker-compose.prod.yml. It is not published to the Internet.
FOXGEN_S3_ENDPOINT_URL=http://minio:9000
FOXGEN_S3_REGION=us-east-1
FOXGEN_S3_BUCKET=foxgen-media
FOXGEN_S3_ACCESS_KEY_ID=<random-minio-access-key>
FOXGEN_S3_SECRET_ACCESS_KEY=<long-random-minio-secret>
FOXGEN_S3_FORCE_PATH_STYLE=true
FOXGEN_S3_CREATE_BUCKET=false
